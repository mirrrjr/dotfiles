# GIMP gimprc
# 
# This is your personal gimprc file.  Any variable defined in this file takes
# precedence over the value defined in the system-wide gimprc:
# /etc/gimp/3.0/gimprc
# Most values can be set within GIMP by changing some options in the
# Preferences dialog.

(temp-path "/home/mirjr/Documents/gimp")
(prev-language "American English")
(config-version "3.2.4")
(default-image
    (width 1920)
    (height 1080)
    (unit pixels)
    (xresolution 300)
    (yresolution 300)
    (resolution-unit inches)
    (image-type rgb)
    (precision u8-non-linear)
    (color-profile NULL)
    (simulation-profile NULL)
    (simulation-bpc no)
    (simulation-intent relative-colorimetric)
    (fill-type white)
    (comment "Created with GIMP"))
(layer-preview-size small)
(color-management
    (mode display)
    (display-profile-from-gdk no)
    (display-rendering-intent relative-colorimetric)
    (display-use-black-point-compensation yes)
    (display-optimize yes)
    (simulation-rendering-intent perceptual)
    (simulation-use-black-point-compensation no)
    (simulation-optimize yes)
    (simulation-gamut-check no)
    (out-of-gamut-color
        (color "RGBA float" 16 "\0\0\200\77\0\0\0\0\0\0\200\77\0\0\200\77" 0))
    (show-rgb-u8 yes)
    (show-hsv yes))
(import-raw-plug-in "${gimp_plug_in_dir}/plug-ins/file-raw-placeholder/file-raw-placeholder")
(transparency-type gray-only)
(default-show-all yes)
(monitor-xresolution 102)
(monitor-yresolution 103)
(default-view
    (show-menubar no)
    (show-statusbar no)
    (show-rulers yes)
    (show-scrollbars no)
    (show-selection yes)
    (show-layer-boundary yes)
    (show-canvas-boundary yes)
    (show-guides yes)
    (show-grid no)
    (show-sample-points yes)
    (snap-to-guides yes)
    (snap-to-grid yes)
    (snap-to-canvas yes)
    (snap-to-path yes)
    (snap-to-bbox yes)
    (snap-to-equidistance yes)
    (padding-mode default)
    (padding-color
        (color "R'G'B'A float" 16 "\0\0\200\77\0\0\200\77\0\0\200\77\0\0\200\77" 0))
    (padding-in-show-all no))
(default-fullscreen-view
    (show-menubar yes)
    (show-statusbar no)
    (show-rulers yes)
    (show-scrollbars no)
    (show-selection yes)
    (show-layer-boundary yes)
    (show-canvas-boundary yes)
    (show-guides yes)
    (show-grid no)
    (show-sample-points yes)
    (snap-to-guides yes)
    (snap-to-grid yes)
    (snap-to-canvas yes)
    (snap-to-path yes)
    (snap-to-bbox yes)
    (snap-to-equidistance yes)
    (padding-mode default)
    (padding-color
        (color "R'G'B'A float" 16 "\0\0\200\77\0\0\200\77\0\0\200\77\0\0\200\77" 0))
    (padding-in-show-all no))
(toolbox-wilber no)
(theme "System")
(override-theme-icon-size yes)
(custom-icon-size small)
(font-relative-size 0.80000000000000004)
(custom-title-bar yes)
(selection-shrink-radius 75)
(fill-options
    (style fg-color)
    (custom-style solid-color)
    (antialias yes)
    (feather no)
    (feather-radius 10))
(stroke-options
    (style fg-color)
    (custom-style solid-color)
    (antialias yes)
    (feather no)
    (feather-radius 10)
    (method line)
    (width 6)
    (unit pixels)
    (cap-style butt)
    (join-style miter)
    (miter-limit 10)
    (dash-offset 0)
    (dash-info 0)
    (emulate-brush-dynamics no))


# end of gimprc
(plug-in-path "${gimp_plug_in_dir}/plug-ins:/usr/local/lib/gimp/3.0/plug-ins")
