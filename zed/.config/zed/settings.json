{
    // ── Appearance ──────────────────────────────────────────────────────────────
    "terminal": {
        "font_size": 16.0,
        "font_family": "JetBrainsMono Nerd Font Mono"
    },
    "base_keymap": "VSCode",
    "sticky_scroll": {
        "enabled": false
    },
    "mouse_wheel_zoom": true,
    "minimap": {
        "show": "never"
    },
    "max_tabs": 10,
    "autosave": "off",
    "auto_indent_on_paste": true,
    "linked_edits": true,
    "use_on_type_format": true,
    "theme": {
        "mode": "dark",
        "light": "Ayu Light",
        "dark": "Ayu Dark",
    },
    // "theme_overrides": {
    //     "Catppuccin Espresso (Blur)": {
    //         "background": "#000",
    //         "title_bar.background": "#000",
    //         "editor.background": "#000",
    //         "panel.overlay_hover": "#333",
    //         "syntax": {
    //             "comment": {
    //                 "font_style": "italic",
    //             },
    //             "comment.doc": {
    //                 "font_style": "italic",
    //             },
    //         },
    //     },
    // },
    "icon_theme": {
        "mode": "dark",
        "light": "Catppuccin Latte",
        "dark": "Catppuccin Latte"
    },
    "ui_font_family": "JetBrainsMono Nerd Font Propo",
    "ui_font_size": 16,

    // ── Editor ───────────────────────────────────────────────────────────────────
    "buffer_font_family": "JetBrainsMono Nerd Font Mono",
    "buffer_font_size": 16,
    "tab_size": 4,
    "vim_mode": true,
    "relative_line_numbers": "enabled",
    "cursor_shape": "bar",
    "cursor_blink": false,
    "selection_highlight": false,
    "drag_and_drop_selection": {
        "enabled": false,
    },
    "seed_search_query_from_cursor": "never",
    "current_line_highlight": "none",
    "show_whitespaces": "none",
    // "autosave": {
    //     "after_delay": {
    //         "milliseconds": 1000,
    //     },
    // },
    "git": {
        "git_gutter": "hide",
        "inline_blame": {
            "enabled": false,
        },
    },

    // ── UI Chrome ────────────────────────────────────────────────────────────────
    "title_bar": {
        "show_onboarding_banner": false,
        "show_project_items": false,
        "show_branch_name": false,
        "show_user_menu": false,
    },
    "toolbar": {
        "quick_actions": false,
    },
    "tab_bar": {
        "show_tab_bar_buttons": false,
        "show": false,
        "show_nav_history_buttons": false,
    },
    "status_bar": {
        "experimental.show": false,
    },
    "scrollbar": {
        "show": "never",
        "cursors": false,
        "axes": {
            "horizontal": false,
            "vertical": false,
        },
    },
    "project_panel": {
        "dock": "left",
        "default_width": 300,
        "hide_root": true,
        "auto_fold_dirs": false,
        "starts_open": false,
        "git_status": false,
        "sticky_scroll": false,
        "scrollbar": {
            "show": "never",
        },
        "indent_guides": {
            "show": "never",
        },
    },
    "gutter": {
        "min_line_number_digits": 0,
        "folds": false,
        "runnables": false,
        "breakpoints": false,
        "line_numbers": true,
    },

    // ── AI / Agent ───────────────────────────────────────────────────────────────
    "disable_ai": true,
    "agent": {
        "default_model": {
            "provider": "zed.dev",
            "model": "claude-haiku-4.5",
        },
        "inline_alternatives": [
            {
                "provider": "zed.dev",
                "model": "gpt-4-mini",
            },
            {
                "provider": "zed.dev",
                "model": "gemini-3-flash",
            },
        ],
    },

    // ── Session ──────────────────────────────────────────────────────────────────
    "session": {
        "trust_all_worktrees": true,
    },

    // ── Languages ────────────────────────────────────────────────────────────────
    "languages": {
        "TypeScript": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
            "formatter": "language_server",
            "prettier": {
                "allowed": true,
            },
        },
        "JavaScript": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
            "prettier": {
                "allowed": false,
            },
        },
        "PHP": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
        },
        "Go": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
        },
        "Rust": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
        },
        "Markdown": {
            "auto_indent_on_paste": true,
            "linked_edits": true,
            "use_on_type_format": true,
            "tab_size": 4,
            "format_on_save": "off",
            "colorize_brackets": true,
            "formatter": "language_server",
        },
    },
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },
}
