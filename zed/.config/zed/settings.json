{
    // ── Appearance ──────────────────────────────────────────────────────────────
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                }
            },
            "enable_lsp_tasks": true
        }
    },
    "theme": {
        "mode": "system",
        "light": "Catppuccin Espresso (Blur) [Light]",
        "dark": "Catppuccin Espresso (Blur)",
    },
    "theme_overrides": {
        "Catppuccin Espresso (Blur)": {
            "background": "#000",
            "title_bar.background": "#000",
            "editor.background": "#000",
            "panel.overlay_hover": "#333",
            "syntax": {
                "comment": {
                    "font_style": "italic",
                },
                "comment.doc": {
                    "font_style": "italic",
                },
            },
        },
    },
    "icon_theme": "Catppuccin Latte",
    "ui_font_family": "JetBrainsMono Nerd Font Propo",
    "ui_font_size": 16,

    // ── Editor ───────────────────────────────────────────────────────────────────
    "buffer_font_family": "JetBrainsMono Nerd Font Propo",
    "buffer_font_size": 16,
    "tab_size": 4,
    "vim_mode": true,
    "relative_line_numbers": "enabled",
    "cursor_shape": "bar",
    "cursor_blink": false,
    "selection_highlight": false,
    "drag_and_drop_selection": {
        "enabled": false,
    },
    "seed_search_query_from_cursor": "never",
    "current_line_highlight": "none",
    "show_whitespaces": "none",
    // "autosave": {
    //     "after_delay": {
    //         "milliseconds": 1000,
    //     },
    // },
    "git": {
        "git_gutter": "hide",
        "inline_blame": {
            "enabled": false,
        },
    },

    // ── UI Chrome ────────────────────────────────────────────────────────────────
    "title_bar": {
        "show_onboarding_banner": false,
        "show_project_items": false,
        "show_branch_name": false,
        "show_user_menu": false,
    },
    "toolbar": {
        "quick_actions": false,
    },
    "tab_bar": {
        "show": false,
        "show_nav_history_buttons": false,
    },
    "status_bar": {
        "experimental.show": false,
    },
    "scrollbar": {
        "show": "never",
        "cursors": false,
        "axes": {
            "horizontal": false,
            "vertical": false,
        },
    },
    "project_panel": {
        "dock": "left",
        "default_width": 300,
        "hide_root": true,
        "auto_fold_dirs": false,
        "starts_open": false,
        "git_status": false,
        "sticky_scroll": false,
        "scrollbar": {
            "show": "never",
        },
        "indent_guides": {
            "show": "never",
        },
    },
    "gutter": {
        "min_line_number_digits": 0,
        "folds": false,
        "runnables": false,
        "breakpoints": false,
        "line_numbers": true,
    },

    // ── AI / Agent ───────────────────────────────────────────────────────────────
    "disable_ai": true,
    "agent": {
        "default_model": {
            "provider": "zed.dev",
            "model": "claude-haiku-4.5",
        },
        "inline_alternatives": [
            {
                "provider": "zed.dev",
                "model": "gpt-4-mini",
            },
            {
                "provider": "zed.dev",
                "model": "gemini-3-flash",
            },
        ],
    },

    // ── Session ──────────────────────────────────────────────────────────────────
    "session": {
        "trust_all_worktrees": true,
    },

    // ── Languages ────────────────────────────────────────────────────────────────
    "languages": {
        "TypeScript": {
            "tab_size": 4,
            "formatter": "language_server",
            "prettier": {
                "allowed": true,
            },
        },
        "JavaScript": {
            "tab_size": 4,
            "prettier": {
                "allowed": false,
            },
        },
        "PHP": {
            "tab_size": 4,
        },
        "Go": {
            "tab_size": 4,
        },
        "Rust": {
            "tab_size": 4,
        },
    },
}
