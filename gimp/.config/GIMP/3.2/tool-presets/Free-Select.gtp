# GIMP tool preset file

(icon-name "gimp-tool-free-select")
(name "Free Select")
(tool-options "GimpSelectionOptions"
    (tool "gimp-free-select-tool"))
(use-fg-bg no)
(use-opacity-paint-mode no)
(use-brush no)
(use-dynamics no)
(use-mypaint-brush no)
(use-gradient no)
(use-pattern no)
(use-palette no)
(use-font no)

# end of GIMP tool preset file
